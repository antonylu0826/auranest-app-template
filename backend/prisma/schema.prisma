generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Default policy controlling how permission checks behave for a role.
/// DENY_ALL: only explicitly granted permissions pass (default for all new roles).
/// READ_ALL: all *_READ permissions pass automatically; writes/deletes require explicit grants.
/// ALLOW_ALL: every permission check passes — custom ADMIN-level bypass for non-system roles.
enum PermissionPolicy {
  DENY_ALL
  READ_ALL
  ALLOW_ALL
}

/// Granular permission assignable to a custom Role. ADMIN bypasses all checks;
/// these values are only evaluated for non-ADMIN roles. Embedded in the JWT at login.
enum Permission {
  // User management
  USERS_READ
  USERS_CREATE
  USERS_UPDATE
  USERS_DELETE
  // API key management
  API_KEYS_READ
  API_KEYS_CREATE
  API_KEYS_DELETE
  // Calendar
  CALENDAR_READ
  CALENDAR_CREATE
  CALENDAR_UPDATE
  CALENDAR_DELETE
  // Events
  EVENT_READ
  EVENT_CREATE
  EVENT_UPDATE
  EVENT_DELETE
}

/// System role or custom role. ADMIN and USER are seeded system roles and cannot be deleted. @internal
/// Marked @internal so MetaService excludes it from the API-key scope catalog.
model Role {
  id               String           @id @default(cuid())
  /// Unique machine name, e.g. "ADMIN", "USER", "EDITOR". Used in JWT roleName field.
  name             String           @unique
  /// Human-readable label shown in UI.
  displayName      String           @map("display_name")
  /// System roles (ADMIN / USER) cannot be deleted or renamed.
  isSystem         Boolean          @default(false) @map("is_system")
  /// Default deny; explicit permissions in RolePermission are additive on top of the policy.
  permissionPolicy PermissionPolicy @default(DENY_ALL) @map("permission_policy")
  permissions      RolePermission[]
  userRoles        UserRole[]
  apiKeys          ApiKey[]
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("roles")
}

/// Junction table between Role and Permission enum values. @internal
/// Marked @internal so MetaService excludes it from the auto-derived scope catalog.
model RolePermission {
  id         String     @id @default(cuid())
  roleId     String     @map("role_id")
  permission Permission
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
  @@map("role_permissions")
}

/// Junction table supporting many-to-many User ↔ Role assignment. @internal
model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, roleId])
  @@map("user_roles")
}

/// System user account. Used for authentication in local-auth mode.
/// In OIDC mode the password field is unused; identity is verified via JWKS.
model User {
  id        String   @id @default(cuid())
  /// Login email, must be unique across the system.
  email     String   @unique
  password  String
  /// Display name shown in UI; optional.
  name      String?
  /// Soft-disable without deleting — preserves audit history.
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userRoles      UserRole[]

  calendars      Calendar[]
  ownedEvents    Event[]
  eventAttendees EventAttendee[]

  @@map("users")
}

/// Ownership type of a calendar.
enum CalendarType {
  PERSONAL // private calendar owned by one user
  SHARED   // explicitly shared with selected members via CalendarMember
}

/// Confirmation status of an event.
enum EventStatus {
  CONFIRMED  // event is confirmed and will happen
  TENTATIVE  // event is tentative, may change
  CANCELLED  // event has been cancelled
}

/// Visibility of event details to non-attendees.
enum EventPrivacy {
  DEFAULT  // inherits calendar default visibility
  PUBLIC   // title and details visible to all calendar members
  PRIVATE  // title hidden from non-attendees (shows as "Busy")
}

/// Display color for a calendar or event. Stored as a hex color string (e.g. "#4285F4").
enum CalendarColor {
  BLUE    // #4285F4 — Google Calendar default blue
  GREEN   // #0F9D58
  RED     // #DB4437
  YELLOW  // #F4B400
  PURPLE  // #7C4DFF
  PINK    // #E91E63
  TEAL    // #009688
  GRAY    // #616161
}

/// Attendee RSVP status for an event invitation.
enum AttendeeStatus {
  PENDING   // invitation sent, no response yet
  ACCEPTED  // attendee confirmed attendance
  DECLINED  // attendee declined
  TENTATIVE // attendee is unsure
}

/// A calendar owned by a user (e.g. "Work", "Personal"). Events belong to a calendar.
model Calendar {
  id          String        @id @default(cuid())
  /// Human-readable calendar name, e.g. "Work" or "Personal".
  name        String
  /// Optional description of the calendar's purpose.
  description String?
  /// Whether this is a private personal calendar or a shared one.
  type        CalendarType  @default(PERSONAL)
  /// Display color used in the UI for this calendar's events.
  color       CalendarColor @default(BLUE)
  /// Whether this calendar is visible in the UI by default.
  isVisible   Boolean       @default(true) @map("is_visible")
  /// The user's primary calendar; auto-created on first login. Cannot be deleted.
  isPrimary   Boolean       @default(false) @map("is_primary")
  ownerId     String        @map("owner_id")
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  events Event[]

  @@map("calendars")
}

/// A calendar event. Supports all-day events, timed events, and optional recurrence.
model Event {
  id          String        @id @default(cuid())
  /// Short title displayed on the calendar grid.
  title       String
  /// Optional longer description or agenda.
  description String?
  /// Physical or virtual location of the event.
  location    String?
  /// IANA timezone name for this event, e.g. "Asia/Taipei". Used for RRULE expansion.
  timezone    String        @default("Asia/Taipei")
  /// Event start date-time (UTC). For all-day events this is midnight UTC of the start date.
  startAt     DateTime      @map("start_at")
  /// Event end date-time (UTC). For all-day events this is midnight UTC of the day after the last day.
  endAt       DateTime      @map("end_at")
  /// When true, startAt/endAt represent dates only; time-of-day is ignored in the UI.
  isAllDay    Boolean       @default(false) @map("is_all_day")
  /// Confirmation status of this event.
  status      EventStatus   @default(CONFIRMED)
  /// Visibility of event details to non-attendees.
  privacy     EventPrivacy  @default(DEFAULT)
  /// Optional iCalendar RRULE string for recurring events (e.g. "FREQ=WEEKLY;BYDAY=MO,WE,FR").
  recurrenceRule String?    @map("recurrence_rule")
  /// For a recurrence override or cancellation: points to the master event.
  recurringEventId String?  @map("recurring_event_id")
  /// For a recurrence override or cancellation: the original UTC start of the occurrence being replaced.
  originalStartAt  DateTime? @map("original_start_at")
  /// True when this row represents a cancelled occurrence of a recurring event (single-occurrence delete).
  isCancelled Boolean       @default(false) @map("is_cancelled")
  /// Display color override; falls back to the parent calendar's color if null.
  color       CalendarColor?
  /// The calendar this event belongs to.
  calendarId  String        @map("calendar_id")
  calendar    Calendar      @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  /// User who created the event.
  ownerId     String        @map("owner_id")
  owner       User          @relation(fields: [ownerId], references: [id])
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  attendees EventAttendee[]

  @@index([calendarId, startAt])
  @@index([recurringEventId])
  @@map("events")
}

/// Machine-to-machine API key for external integrations (n8n, AI agents).
/// Created by ADMIN only. Raw key is shown once at creation and never stored. @internal
model ApiKey {
  id         String    @id @default(cuid())
  /// Human-readable label, e.g. "n8n production" or "AI agent read-only".
  name       String
  /// First 16 chars of the raw key, shown in lists for identification (e.g. "an_live_a1b2c3d4").
  prefix     String
  /// SHA-256 hash of the raw key. The raw key is never persisted.
  hashedKey  String    @unique @map("hashed_key")
  /// Role this key authenticates as; FK to roles table.
  roleId     String    @map("role_id")
  role       Role      @relation(fields: [roleId], references: [id])
  /// Module-level scopes, e.g. ["events:read","calendars:*"]. "*" = all scopes. Empty = deny all.
  scopes     String[]
  /// Requests per minute. null = system default (60).
  rateLimit  Int?      @map("rate_limit")
  /// Whether this key can be used. Set false to revoke without deleting.
  isActive   Boolean   @default(true) @map("is_active")
  /// Optional expiry. null = never expires.
  expiresAt  DateTime? @map("expires_at")
  /// Email of the ADMIN who created this key. Snapshot string, no FK.
  createdBy  String?   @map("created_by")
  /// Timestamp of last successful authentication with this key.
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("api_keys")
}

/// Tracks which users are invited to an event and their RSVP status.
model EventAttendee {
  id        String         @id @default(cuid())
  eventId   String         @map("event_id")
  event     Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String         @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// RSVP response from the attendee.
  status    AttendeeStatus @default(PENDING)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@unique([eventId, userId])
  @@map("event_attendees")
}
